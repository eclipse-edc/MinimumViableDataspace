meta {
  name: Query Credentials by Type
  type: http
  seq: 3
}

get {
  url: {{CS_URL}}/api/identity/v1alpha/participants/{{PARTICIPANT_CONTEXT_ID}}/credentials?type=ManufacturerCredential
  body: none
