meta {
  name: Activate Participant
  type: http
  seq: 7
}

post {
  url: {{CS_URL}}/api/identity/v1alpha/participants/{{PARTICIPANT_CONTEXT_ID}}/state?isActive=true
  body: json
  auth: inherit
}

params:query {
  isActive: true
}

body:json {
  {
      "roles":[],
      "serviceEndpoints":[],
      "isActive": true,
      "participantId": "foobar",
      "did": "did:web:foobar",
      "key":{
          "keyId": "key1",
          "privateKeyAlias": "foobar-alias",
          "keyGeneratorParams":{
              "algorithm": "EC",
              "curve": "secp256r1"
          }
      }
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
